# LLM provider routing hint. The backend keeps using OpenAI-compatible Chat Completions.
# Supported values: openai, groq, openrouter, gemini
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-your-api-key-here

# OPENAI_BASE_URL can be used for Groq / OpenRouter / Gemini and other OpenAI-compatible APIs.
# Leave empty to use the default base URL for LLM_PROVIDER.
# Examples:
# - OpenAI: https://api.openai.com/v1
# - Groq: https://api.groq.com/openai/v1
# - OpenRouter: https://openrouter.ai/api/v1
OPENAI_BASE_URL=

OPENAI_MODEL=gpt-4o
FRONTEND_ORIGINS=http://localhost:5173,https://your-vercel-domain.vercel.app
